includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    ignoreErrors:
        # Pest arch() tests use dynamic method chaining that PHPStan cannot resolve
        -
            identifier: method.notFound
            path: tests/Arch/*
        # Pest test closures use $this->app via Orchestra TestCase magic
        -
            identifier: property.notFound
            path: tests/Feature/*
        # Pest Expectation->not is a magic property
        -
            identifier: property.notFound
            path: tests/Unit/*
            reportUnmatched: false
        # Mockery expectation chains (shouldReceive()->andReturn()) return union types
        -
            identifier: method.notFound
            path: tests/Feature/*
            reportUnmatched: false
        # Mockery in test helpers (GatewayFactory)
        -
            identifier: method.notFound
            path: tests/Helpers/*
        # Mockery mocks return MockInterface — type mismatch when passed as typed parameter
        -
            identifier: argument.type
            path: tests/Helpers/GatewayFactory.php
        -
            identifier: argument.type
            path: tests/Feature/Transport/*
            reportUnmatched: false
        -
            identifier: argument.type
            path: tests/Feature/Auth/*
            reportUnmatched: false
        -
            identifier: argument.type
            path: tests/Unit/Auth/*
            reportUnmatched: false
        -
            identifier: argument.type
            path: tests/Unit/Parsing/ResponseMapperTest.php
        -
            identifier: argument.type
            path: tests/Feature/StreamingTest.php
        # Log::shouldReceive/shouldHaveReceived — Mockery facade spying
        -
            identifier: staticMethod.notFound
            path: tests/Feature/ErrorHandlingTest.php
            reportUnmatched: false
        -
            identifier: staticMethod.notFound
            path: tests/Feature/Auth/*
            reportUnmatched: false
        # Saloon MockClient::getLastPendingRequest() returns nullable
        -
            identifier: method.nonObject
            path: tests/Feature/*
            reportUnmatched: false
        # Test helper function return type
        -
            identifier: missingType.iterableValue
            path: tests/*
            reportUnmatched: false
