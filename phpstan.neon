includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    ignoreErrors:
        # Pest arch() tests use dynamic method chaining that PHPStan cannot resolve
        -
            identifier: method.notFound
            path: tests/Arch/*
        # Pest test closures use $this->app via Orchestra TestCase magic
        -
            identifier: property.notFound
            path: tests/Feature/*
        # Pest Expectation->not is a magic property
        -
            identifier: property.notFound
            path: tests/Unit/*
            reportUnmatched: false
        # Mockery mocks return MockInterface which PHPStan cannot match to interface types
        -
            identifier: argument.type
            path: tests/*
        # Mockery expectation chains (shouldReceive()->once()->andReturn()) return union types
        -
            identifier: method.notFound
            path: tests/Feature/*
        # Log::spy() adds shouldHaveReceived/shouldNotHaveReceived which PHPStan can't resolve
        -
            identifier: staticMethod.notFound
            path: tests/Feature/*
        # json_decode with file_get_contents in test assertions
        -
            identifier: argument.type
            path: tests/Unit/Auth/CredentialStoreTest.php
            reportUnmatched: false
