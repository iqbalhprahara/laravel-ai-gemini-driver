{
    "name": "ursamajeur/laravel-ai-gemini-driver",
    "description": "Laravel AI SDK custom provider exposing Google's CloudCode-PA v1internal API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "gemini",
        "cloudcode"
    ],
    "homepage": "https://github.com/iqbalhprahara/laravel-ai-gemini-driver",
    "support": {
        "issues": "https://github.com/iqbalhprahara/laravel-ai-gemini-driver/issues",
        "source": "https://github.com/iqbalhprahara/laravel-ai-gemini-driver"
    },
    "authors": [
        {
            "name": "Ursamajeur"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/ai": "^0.1",
        "saloonphp/laravel-plugin": "^3.0",
        "saloonphp/saloon": "^3.0"
    },
    "require-dev": {
        "laravel/boost": "^1.0|^2.0",
        "laravel/pint": "^1.27.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ursamajeur\\CloudCodePA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ursamajeur\\CloudCodePA\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ursamajeur\\CloudCodePA\\CloudCodeServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": [
            "pint --format agent",
            "phpstan --memory-limit=-1"
        ],
        "test": "pest",
        "test:lint": "pint --test --format agent",
        "test:types": "phpstan",
        "check": [
            "@composer lint",
            "@composer test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
